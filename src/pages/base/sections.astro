---
import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Base / Page Sections" description="Full-page marketing and content sections ready to drop into landing pages. 6 components.">

  <header class="bg-white border-b border-gray-200 dark:bg-gray-900 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div>
        <a href="/base/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Base Components</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Page Sections</h1>
      </div>
      <a href="/base/" class="text-xs text-gray-500 hover:text-gray-800 border border-gray-200 dark:text-gray-400 dark:hover:text-gray-200 dark:border-gray-600 rounded px-3 py-1.5">← All categories</a>
    </div>
  </header>

  <nav class="bg-white border-b border-gray-100 px-6 py-2">
    <div class="max-w-4xl mx-auto flex gap-5 text-sm">
      <a href="#hero" class="text-gray-400 hover:text-gray-700 py-1">Hero</a>
      <a href="#cta" class="text-gray-400 hover:text-gray-700 py-1">CTA</a>
      <a href="#feature-grid" class="text-gray-400 hover:text-gray-700 py-1">Feature Grid</a>
      <a href="#testimonial" class="text-gray-400 hover:text-gray-700 py-1">Testimonial</a>
      <a href="#pricing-table" class="text-gray-400 hover:text-gray-700 py-1">Pricing Table</a>
      <a href="#faq" class="text-gray-400 hover:text-gray-700 py-1">FAQ</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-16">

    <section id="hero">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Hero</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Full-width intro section with headline, subheading, and primary call-to-action.</p>
        <a href="/base/components/hero.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <section class="relative overflow-hidden bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">

      <!-- Subtle background treatment -->
      <div class="absolute inset-0 bg-gradient-to-br from-slate-50 to-white dark:from-gray-900 dark:to-gray-800 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-slate-100 dark:bg-slate-800/30 rounded-full translate-x-1/2 -translate-y-1/2 blur-3xl opacity-60 pointer-events-none" aria-hidden="true"></div>

      <div class="relative px-8 pt-20 pb-12 sm:px-16 sm:pt-28 text-center">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 rounded-full border border-slate-200 dark:border-slate-700">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          Now in public beta
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-white leading-tight max-w-3xl mx-auto">
          Turn your data into<br class="hidden sm:block"/>
          decisions that matter
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">
          Meridian connects your product analytics, revenue data, and user behavior
          into a single intelligence layer. Understand what's working before your next
          board meeting.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-slate-900 dark:bg-white dark:text-slate-900 rounded-lg hover:bg-slate-700 dark:hover:bg-slate-100 transition-colors shadow-sm"
          >
            Start for free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Watch demo
          </a>
        </div>

        <!-- Social proof -->
        <p class="mt-8 text-xs text-gray-400 dark:text-gray-600">
          Trusted by 2,400+ teams at companies including Acme Corp, Brightline, and Venture.io
        </p>
      </div>

      <!-- Mock product screenshot placeholder -->
      <div class="relative mx-8 sm:mx-16 mb-10">
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 overflow-hidden shadow-lg">
          <!-- Mock browser chrome -->
          <div class="flex items-center gap-1.5 px-4 py-3 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
            <div class="ml-2 flex-1 max-w-xs h-5 bg-gray-100 dark:bg-gray-800 rounded-sm"></div>
          </div>
          <!-- Mock dashboard -->
          <div class="p-6 grid grid-cols-3 gap-4">
            <div class="col-span-3 sm:col-span-1 bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
              <div class="h-2 w-16 bg-gray-200 dark:bg-gray-700 rounded mb-3"></div>
              <div class="h-8 w-24 bg-gray-900 dark:bg-gray-100 rounded mb-1"></div>
              <div class="h-2 w-20 bg-green-200 dark:bg-green-900 rounded"></div>
            </div>
            <div class="col-span-3 sm:col-span-1 bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
              <div class="h-2 w-20 bg-gray-200 dark:bg-gray-700 rounded mb-3"></div>
              <div class="h-8 w-20 bg-gray-900 dark:bg-gray-100 rounded mb-1"></div>
              <div class="h-2 w-16 bg-blue-200 dark:bg-blue-900 rounded"></div>
            </div>
            <div class="col-span-3 sm:col-span-1 bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
              <div class="h-2 w-14 bg-gray-200 dark:bg-gray-700 rounded mb-3"></div>
              <div class="h-8 w-28 bg-gray-900 dark:bg-gray-100 rounded mb-1"></div>
              <div class="h-2 w-12 bg-red-200 dark:bg-red-900 rounded"></div>
            </div>
            <div class="col-span-3 bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 p-4 h-28">
              <div class="h-2 w-24 bg-gray-200 dark:bg-gray-700 rounded mb-4"></div>
              <div class="flex items-end gap-1 h-14">
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:40%"></div>
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:60%"></div>
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:45%"></div>
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:80%"></div>
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:55%"></div>
                <div class="flex-1 bg-slate-900 dark:bg-slate-200 rounded-t" style="height:90%"></div>
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:70%"></div>
                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height:85%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>
      </div>
    </section>

    <section id="cta">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">CTA</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Call-to-action banner with headline, supporting text, and one or two action buttons.</p>
        <a href="/base/components/cta.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">

    <!-- Variant 1: Full-width banner CTA -->
    <section class="relative overflow-hidden bg-slate-900 dark:bg-slate-800 rounded-xl px-8 py-14 sm:px-16 text-center">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 dark:from-slate-800 dark:via-slate-700 dark:to-slate-800 pointer-events-none" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight">
          Ready to see Meridian in action?
        </h2>
        <p class="mt-4 text-base sm:text-lg text-slate-300 max-w-xl mx-auto leading-relaxed">
          Join 2,400+ teams who've replaced guesswork with data. Set up takes less than ten minutes.
          No credit card required.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-slate-900 bg-white rounded-lg hover:bg-slate-100 transition-colors shadow-sm"
          >
            Get started free
          </a>
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white border border-slate-600 rounded-lg hover:bg-slate-800 dark:hover:bg-slate-700 transition-colors"
          >
            Talk to sales
          </a>
        </div>
        <p class="mt-5 text-sm text-slate-400">14-day free trial &middot; Cancel anytime &middot; SOC 2 Type II certified</p>
      </div>
    </section>

    <!-- Variant 2: Card-style centered CTA -->
    <section class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-8 py-10 text-center max-w-lg mx-auto">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 mb-5">
        <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">
        Start your free trial today
      </h2>
      <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
        No setup fees. No long-term contracts. Just powerful analytics for your team, ready in minutes.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="#"
          class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-slate-900 dark:bg-white dark:text-slate-900 rounded-lg hover:bg-slate-700 dark:hover:bg-slate-100 transition-colors"
        >
          Create free account
        </a>
        <a
          href="#"
          class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
        >
          Learn more
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
      </div>
    </section>

    <section id="feature-grid">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Feature Grid</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Multi-feature showcase grid with icon, title, and short description per feature.</p>
        <a href="/base/components/feature-grid.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <section class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 px-8 py-14 sm:px-12">

      <!-- Section header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
          Everything your team needs to move fast
        </h2>
        <p class="mt-3 text-base text-gray-600 dark:text-gray-400 max-w-xl mx-auto leading-relaxed">
          Meridian brings together the tools and insights that high-performing product teams rely on every day.
        </p>
      </div>

      <!-- 3-column feature grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Feature 1 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0">
            <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Real-time dashboards</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Monitor key metrics as they happen. Live event streams, rolling windows, and auto-refreshing charts keep your team in sync without manual exports.
            </p>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0">
            <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Cohort analysis</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Segment users by any combination of attributes and track their behavior over time. Understand which acquisition channels drive long-term retention.
            </p>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0">
            <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Funnel visualization</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Map every step of your user journey and identify exactly where drop-off occurs. Compare funnels across segments, time periods, and experiment variants.
            </p>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0">
            <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Intelligent alerts</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Set threshold-based or anomaly-detection alerts on any metric. Get notified in Slack, email, or PagerDuty before a problem escalates.
            </p>
          </div>
        </div>

        <!-- Feature 5 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0">
            <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">SQL explorer</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Query your raw event data directly with a built-in SQL editor. Save queries, share results with your team, and schedule automated reports.
            </p>
          </div>
        </div>

        <!-- Feature 6 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0">
            <svg class="w-5 h-5 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Data warehouse sync</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Push clean, modeled data to Snowflake, BigQuery, or Redshift on a schedule you control. No ETL pipelines to maintain.
            </p>
          </div>
        </div>

      </div>
    </section>
      </div>
    </section>

    <section id="testimonial">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Testimonial</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Pull quote with attribution name, title, and optional avatar.</p>
        <a href="/base/components/testimonial.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <section class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 px-8 py-14 sm:px-12">

      <!-- Section header -->
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Trusted by teams that move fast</h2>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Don't take our word for it — here's what our customers say.</p>
      </div>

      <!-- Testimonial grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Testimonial 1 -->
        <figure class="flex flex-col justify-between bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-6">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4" aria-label="5 out of 5 stars">
