---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Slate / Actions" description="Slate aesthetic action components: buttons, button groups, links, and dropdowns.">

  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Page header -->
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div>
        <a href="/aesthetics/slate/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Slate</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Actions</h1>
      </div>
      <a href="/aesthetics/slate/" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5">&larr; All categories</a>
    </div>
  </header>

  <!-- Component sections -->
  <main class="max-w-4xl mx-auto px-6 py-10 space-y-16">

    <!-- Button -->
    <section>
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Button</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Primary, secondary, ghost, and destructive button variants with hover and focus states.</p>
        <a href="/aesthetics/slate/components/button.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 dark:border-gray-700 p-6">
        <div class="space-y-6">

          <!-- Variants -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Variants</p>
            <div class="flex flex-wrap gap-3 items-center">
              <!-- Primary -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md bg-[#4F63D2] px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-all dark:focus:ring-offset-slate-900"
              >
                Save changes
              </button>

              <!-- Secondary -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-colors dark:bg-slate-800 dark:text-slate-200 dark:ring-slate-600 dark:hover:bg-slate-700 dark:focus:ring-offset-slate-900"
              >
                Cancel
              </button>

              <!-- Ghost -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-colors dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 dark:focus:ring-offset-slate-900"
              >
                Learn more
              </button>

              <!-- Destructive -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors dark:bg-red-700 dark:hover:bg-red-600 dark:focus:ring-red-500 dark:focus:ring-offset-slate-900"
              >
                Delete account
              </button>
            </div>
          </div>

          <!-- Sizes -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Sizes</p>
            <div class="flex flex-wrap gap-3 items-center">
              <!-- Small -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md bg-[#4F63D2] px-3 py-1.5 text-xs font-medium text-white shadow-sm hover:bg-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-all dark:focus:ring-offset-slate-900"
              >
                Publish
              </button>

              <!-- Medium (default) -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md bg-[#4F63D2] px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-all dark:focus:ring-offset-slate-900"
              >
                Publish
              </button>

              <!-- Large -->
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-md bg-[#4F63D2] px-6 py-3 text-base font-medium text-white shadow-sm hover:bg-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-all dark:focus:ring-offset-slate-900"
              >
                Publish
              </button>
            </div>
          </div>

          <!-- Disabled states -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Disabled</p>
            <div class="flex flex-wrap gap-3 items-center">
              <button
                type="button"
                disabled
                class="inline-flex items-center justify-center rounded-md bg-[#4F63D2] px-4 py-2 text-sm font-medium text-white shadow-sm opacity-50 cursor-not-allowed"
              >
                Save changes
              </button>

              <button
                type="button"
                disabled
                class="inline-flex items-center justify-center rounded-md bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 opacity-50 cursor-not-allowed dark:bg-slate-800 dark:text-slate-200 dark:ring-slate-600"
              >
                Cancel
              </button>

              <button
                type="button"
                disabled
                class="inline-flex items-center justify-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm opacity-50 cursor-not-allowed dark:bg-red-700"
              >
                Delete account
              </button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Button Group -->
    <section>
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Button Group</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Horizontally grouped action buttons with joined borders and shared context.</p>
        <a href="/aesthetics/slate/components/button-group.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 dark:border-gray-700 p-6">
        <div class="space-y-6">

          <!-- Action button group -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Action Group</p>
            <div class="inline-flex rounded-md shadow-sm" role="group" aria-label="Post actions">
              <button
                type="button"
                class="inline-flex items-center px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-l-md hover:bg-slate-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-0 transition-colors dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700"
              >
                <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                </svg>
                Edit
              </button>
              <button
                type="button"
                class="inline-flex items-center px-4 py-2 text-sm font-medium text-slate-700 bg-white border-t border-b border-slate-300 hover:bg-slate-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-0 transition-colors dark:bg-slate-800 dark:text-slate-200 dark:border-slate-600 dark:hover:bg-slate-700"
              >
                <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                </svg>
                Duplicate
              </button>
              <button
                type="button"
                class="inline-flex items-center px-4 py-2 text-sm font-medium text-red-600 bg-white border border-slate-300 rounded-r-md hover:bg-red-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-0 transition-colors dark:bg-slate-800 dark:text-red-400 dark:border-slate-600 dark:hover:bg-slate-700"
              >
                <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg>
                Delete
              </button>
            </div>
          </div>

          <!-- Segmented control -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Segmented Control</p>
            <div class="inline-flex rounded-md bg-slate-200 p-1 dark:bg-slate-700" role="group" aria-label="View mode">
              <button
                type="button"
                class="inline-flex items-center px-4 py-1.5 text-sm font-medium text-white bg-[#4F63D2] rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-colors dark:focus:ring-offset-slate-700"
                aria-pressed="true"
              >
                <svg class="w-4 h-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                </svg>
                Grid
              </button>
              <button
                type="button"
                class="inline-flex items-center px-4 py-1.5 text-sm font-medium text-slate-600 hover:text-slate-900 rounded-md focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-colors dark:text-slate-400 dark:hover:text-slate-100 dark:focus:ring-offset-slate-700"
                aria-pressed="false"
              >
                <svg class="w-4 h-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                </svg>
                List
              </button>
              <button
                type="button"
                class="inline-flex items-center px-4 py-1.5 text-sm font-medium text-slate-600 hover:text-slate-900 rounded-md focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-colors dark:text-slate-400 dark:hover:text-slate-100 dark:focus:ring-offset-slate-700"
                aria-pressed="false"
              >
                <svg class="w-4 h-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                </svg>
                Chart
              </button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Link -->
    <section>
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Link</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Styled anchor with underline, hover, and focus states for inline and standalone use.</p>
        <a href="/aesthetics/slate/components/link.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 dark:border-gray-700 p-6">
        <div class="space-y-6">

          <!-- Inline link in prose -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Inline</p>
            <p class="text-sm text-slate-700 leading-relaxed dark:text-slate-300">
              To get started, read the
              <a href="#" class="text-[#3D4FB8] underline underline-offset-2 decoration-[#6B7BE0] hover:decoration-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors dark:text-[#6B7BE0] dark:decoration-[#3545A0] dark:hover:decoration-[#6B7BE0]">
                documentation
              </a>
              and review the
              <a href="#" class="text-[#3D4FB8] underline underline-offset-2 decoration-[#6B7BE0] hover:decoration-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors dark:text-[#6B7BE0] dark:decoration-[#3545A0] dark:hover:decoration-[#6B7BE0]">
                contribution guidelines
              </a>
              before opening a pull request.
            </p>
          </div>

          <!-- Standalone links -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">Standalone</p>
            <div class="space-y-2">
              <div>
                <a href="#" class="text-sm font-medium text-slate-900 hover:text-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors dark:text-slate-100 dark:hover:text-[#6B7BE0]">
                  View your profile
                </a>
              </div>
              <div>
                <a href="#" class="text-sm font-medium text-slate-900 hover:text-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors dark:text-slate-100 dark:hover:text-[#6B7BE0]">
                  Account settings
                </a>
              </div>
              <div>
                <a href="#" class="text-sm font-medium text-slate-900 hover:text-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors dark:text-slate-100 dark:hover:text-[#6B7BE0]">
                  Sign out
                </a>
              </div>
            </div>
          </div>

          <!-- With arrow icon -->
          <div>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-3">With Icon</p>
            <div class="space-y-2">
              <div>
                <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-900 hover:text-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors group dark:text-slate-100 dark:hover:text-[#6B7BE0]">
                  View changelog
                  <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
              <div>
                <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-900 hover:text-[#3D4FB8] focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 rounded transition-colors group dark:text-slate-100 dark:hover:text-[#6B7BE0]">
                  Open in new tab
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Dropdown -->
    <section>
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Dropdown</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Click-triggered action menu with keyboard navigation and outside-click dismissal.</p>
        <a href="/aesthetics/slate/components/dropdown.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-6 min-h-64">
        <div class="relative inline-block text-left">
          <!-- Trigger -->
          <button
            type="button"
            data-fiord-toggle="fiord-dropdown-menu"
            class="inline-flex items-center gap-2 rounded-md bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-[#4F63D2] focus:ring-offset-2 transition-colors dark:bg-slate-800 dark:text-slate-200 dark:ring-slate-600 dark:hover:bg-slate-700 dark:focus:ring-offset-slate-900"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Options
            <svg class="w-4 h-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </button>

          <!-- Menu -->
          <div
            id="fiord-dropdown-menu"
            data-fiord-menu
            class="hidden absolute left-0 z-10 mt-2 w-52 origin-top-left rounded-lg bg-white shadow-lg ring-1 ring-black/5 focus:outline-none dark:bg-slate-800 dark:ring-white/10"
            role="menu"
            aria-orientation="vertical"
            tabindex="-1"
          >
            <div class="py-1">
              <!-- Edit -->
              <a
                href="#"
                role="menuitem"
                tabindex="-1"
                class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 hover:bg-slate-100 hover:text-slate-900 transition-colors dark:text-slate-200 dark:hover:bg-slate-700 dark:hover:text-slate-100"
              >
                <svg class="w-4 h-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                </svg>
                Edit
              </a>

              <!-- Duplicate -->
