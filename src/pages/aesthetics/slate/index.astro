---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Fiord — Slate Aesthetic"
  description="Slate: professional, measured, neutral. Cool grays with clean lines, Stripe-inspired polish. Suited for enterprise, SaaS, and B2B products."
>

  <!-- Page header -->
  <header class="bg-white border-b border-gray-200 px-6 py-5">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between">
        <div>
          <a href="/aesthetics/" class="text-xs text-gray-400 hover:text-gray-600 uppercase tracking-widest font-medium">Aesthetics</a>
          <h1 class="text-xl font-semibold text-gray-900 mt-0.5">Slate</h1>
        </div>
        <a href="/aesthetics/slate/meta.json" class="text-xs text-gray-500 hover:text-gray-800 border border-gray-200 rounded px-3 py-1.5 transition-colors font-mono">meta.json</a>
      </div>
      <p class="mt-2 text-sm text-gray-500 max-w-2xl">
        Professional, measured, neutral. Cool grays with clean lines, Stripe-inspired polish.
        Suited for enterprise, SaaS, and B2B products.
      </p>
    </div>
  </header>

  <!-- Status -->
  <main class="max-w-4xl mx-auto px-6 py-16">
    <div class="bg-white border border-gray-200 rounded-lg p-8 text-center">
      <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/>
        </svg>
      </div>
      <h2 class="text-sm font-semibold text-gray-900 mb-2">Slate components in progress</h2>
      <p class="text-sm text-gray-500 max-w-md mx-auto leading-relaxed">
        The Slate aesthetic is being built out. Component files will appear at
        <code class="text-xs font-mono bg-gray-100 px-1 py-0.5 rounded">/aesthetics/slate/components/</code>
        as they're completed.
      </p>
      <div class="mt-6 flex items-center justify-center gap-4">
        <a href="/base/" class="text-sm font-medium text-[#4A7FA5] hover:text-[#0F1C2E] transition-colors">
          Browse base components →
        </a>
        <a href="https://github.com/bitfootco/fiord" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
          Track progress on GitHub
        </a>
      </div>
    </div>

    <!-- Design language preview -->
    <div class="mt-10">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-5">Design language</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-white border border-gray-200 rounded-lg p-5">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Palette</h3>
          <div class="space-y-2">
            {[
              { name: 'Primary', value: '#0F172A', hex: '#0F172A' },
              { name: 'Accent', value: '#3B82F6', hex: '#3B82F6' },
              { name: 'Background', value: '#FFFFFF', hex: '#FFFFFF' },
              { name: 'Surface', value: '#F8FAFC', hex: '#F8FAFC' },
              { name: 'Border', value: '#E2E8F0', hex: '#E2E8F0' },
            ].map(({ name, value, hex }) => (
              <div class="flex items-center gap-3">
                <div class="w-5 h-5 rounded border border-gray-200 flex-shrink-0" style={`background-color: ${hex}`}></div>
                <span class="text-xs text-gray-600 flex-1">{name}</span>
                <span class="text-xs font-mono text-gray-400">{value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-lg p-5">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Typography</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs text-gray-400 mb-1">Heading</p>
              <p class="font-semibold text-gray-900 text-sm" style="font-family: Inter, sans-serif;">Inter 600</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-1">Body</p>
              <p class="text-gray-600 text-sm leading-relaxed" style="font-family: Inter, sans-serif;">Inter 400 · 1.6 line height</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-1">Mono</p>
              <p class="font-mono text-gray-500 text-sm">JetBrains Mono 400</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>

</SiteLayout>
