---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Fiord — Slate Aesthetic"
  description="Layered, decisive, geological. Cool blue-gray tones with sharp cleaved edges and matte surfaces."
>

  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Page header -->
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between">
        <div>
          <a href="/aesthetics/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Aesthetics</a>
          <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Slate</h1>
        </div>
        <a href="/aesthetics/slate/meta.json" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5 transition-colors font-mono">meta.json</a>
      </div>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 max-w-2xl">
        Layered, decisive, geological. Cool blue-gray tones with sharp cleaved edges and matte surfaces.
        Built for enterprise dashboards, SaaS products, and B2B platforms
        where clarity and credibility matter most.
      </p>
      <div class="mt-3">
        <a href="/aesthetics/slate/demo/" class="inline-flex items-center gap-1.5 text-sm font-medium text-[#4A7FA5] hover:text-[#0F1C2E] dark:hover:text-white transition-colors">
          View demo
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </header>

  <!-- Component Catalog -->
  <main class="max-w-4xl mx-auto px-6 py-10">
    <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden divide-y divide-gray-100 dark:divide-gray-800">

      <a id="layout" href="/aesthetics/slate/layout/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Layout</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Max-width wrappers, grids, and structural primitives for organizing page content.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="typography" href="/aesthetics/slate/typography/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Typography</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Headings, body text, and content containers that establish textual hierarchy.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="actions" href="/aesthetics/slate/actions/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Actions</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Interactive controls that trigger user-initiated operations.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="forms" href="/aesthetics/slate/forms/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Forms</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">7 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Input controls and composed layouts for collecting user data.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="data" href="/aesthetics/slate/data/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Data Display</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Components for presenting structured information, metrics, and content collections.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="navigation" href="/aesthetics/slate/navigation/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Navigation</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Wayfinding components that help users move through an application or site.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="overlays" href="/aesthetics/slate/overlays/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Overlays</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">5 components</span>
            <span class="text-xs bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 px-1.5 py-0.5 rounded font-mono">JS</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Floating layers that display content or interactions above the page. All include vanilla JS.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="sections" href="/aesthetics/slate/sections/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Page Sections</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Full-page marketing and content sections ready to drop into landing pages.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

    </div>

    <p class="mt-6 text-xs text-gray-400">
      42 components across 8 categories. Copy from <a href="/aesthetics/slate/components/" class="hover:text-gray-600 underline underline-offset-2">individual component pages</a>, not from here.
    </p>

    <!-- Design language preview -->
    <div class="mt-10">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-5">Design language</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-white border border-gray-200 rounded-lg p-5">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Palette</h3>
          <div class="space-y-2">
            {[
              { name: 'Primary', value: '#0F172A', hex: '#0F172A' },
              { name: 'Accent', value: '#4F63D2', hex: '#4F63D2' },
              { name: 'Background', value: '#FFFFFF', hex: '#FFFFFF' },
              { name: 'Surface', value: '#F8FAFC', hex: '#F8FAFC' },
              { name: 'Border', value: '#E2E8F0', hex: '#E2E8F0' },
            ].map(({ name, value, hex }) => (
              <div class="flex items-center gap-3">
                <div class="w-5 h-5 rounded border border-gray-200 flex-shrink-0" style={`background-color: ${hex}`}></div>
                <span class="text-xs text-gray-600 flex-1">{name}</span>
                <span class="text-xs font-mono text-gray-400">{value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-lg p-5">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Typography</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs text-gray-400 mb-1">Heading</p>
              <p class="font-semibold text-gray-900 text-sm" style="font-family: Outfit, sans-serif;">Outfit 600</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-1">Body</p>
              <p class="text-gray-600 text-sm leading-relaxed" style="font-family: 'Plus Jakarta Sans', sans-serif;">Plus Jakarta Sans 400 · 1.6 line height</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-1">Mono</p>
              <p class="font-mono text-gray-500 text-sm">JetBrains Mono 400</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>

</SiteLayout>
