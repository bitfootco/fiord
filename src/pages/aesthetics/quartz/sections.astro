---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Quartz / Page Sections" description="Full-page marketing and content sections in the Quartz aesthetic. Hero, CTA, feature grid, testimonial, pricing table, and FAQ components.">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700&family=Instrument+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Page header -->
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div>
        <a href="/aesthetics/quartz/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Quartz</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Page Sections</h1>
      </div>
      <a href="/aesthetics/quartz/" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5">← All categories</a>
    </div>
  </header>

  <nav class="bg-white border-b border-gray-100 dark:bg-gray-900 dark:border-gray-700 px-6 py-2">
    <div class="max-w-4xl mx-auto flex gap-5 text-sm">
      <a href="#hero" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Hero</a>
      <a href="#cta" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">CTA</a>
      <a href="#feature-grid" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Feature Grid</a>
      <a href="#testimonial" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Testimonial</a>
      <a href="#pricing-table" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Pricing Table</a>
      <a href="#faq" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">FAQ</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-16">

    <section id="hero">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Hero</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Full-width intro section with headline, subheading, and primary call-to-action.</p>
        <a href="/aesthetics/quartz/components/hero.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
    <section class="relative overflow-hidden rounded-lg border border-quartz-200 dark:border-quartz-800 bg-white dark:bg-quartz-900">

      <!-- Subtle prismatic background treatment -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-[#0891B2]/8 rounded-full translate-x-1/2 -translate-y-1/2 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-1/4 w-72 h-72 bg-[#7C3AED]/5 rounded-full translate-y-1/3 blur-3xl pointer-events-none" aria-hidden="true"></div>

      <div class="relative px-8 pt-20 pb-12 sm:px-16 sm:pt-28 text-center">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-semibold text-quartz-700 dark:text-quartz-300 bg-[#ECFEFF] dark:bg-[#0891B2]/20 rounded-full border border-[#0891B2]/20 dark:border-[#06B6D4]/30">
          <span class="w-1.5 h-1.5 rounded-full bg-[#0891B2] dark:bg-[#06B6D4]"></span>
          Now processing $2B+ monthly
        </div>

        <!-- Headline -->
        <h1 class="font-['Bricolage_Grotesque'] text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-quartz-900 dark:text-white leading-tight max-w-3xl mx-auto">
          Financial operations,<br class="hidden sm:block"/>
          finally clear
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-lg sm:text-xl text-quartz-600 dark:text-quartz-300 leading-relaxed max-w-2xl mx-auto font-['Instrument_Sans']">
          Clearledger unifies your accounts payable, expense management, and corporate
          cards into one intelligent platform. Close your books in hours, not weeks.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-[#0891B2] rounded hover:bg-[#0E7490] transition-all shadow-lg shadow-[#0891B2]/25"
          >
            Start for free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-quartz-700 dark:text-quartz-300 border border-quartz-300 dark:border-quartz-600 rounded hover:bg-quartz-50 dark:hover:bg-quartz-800 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Watch demo
          </a>
        </div>

        <!-- Social proof -->
        <p class="mt-8 text-xs text-quartz-500 dark:text-quartz-400">
          Trusted by 1,800+ finance teams at companies including NovaCorp, Ridgeline, and Apex Financial
        </p>
      </div>

      <!-- Mock product screenshot placeholder -->
      <div class="relative mx-8 sm:mx-16 mb-10">
        <div class="rounded-lg border border-quartz-200 dark:border-quartz-700 bg-quartz-50 dark:bg-quartz-800/50 overflow-hidden shadow-2xl shadow-[rgba(15,30,46,0.15)]">
          <!-- Mock browser chrome -->
          <div class="flex items-center gap-1.5 px-4 py-3 bg-quartz-100 dark:bg-quartz-900 border-b border-quartz-200 dark:border-quartz-700">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
            <div class="ml-2 flex-1 max-w-xs h-5 bg-quartz-200 dark:bg-quartz-800 rounded-sm"></div>
          </div>
          <!-- Mock dashboard -->
          <div class="p-6 grid grid-cols-3 gap-4 bg-white dark:bg-quartz-900">
            <div class="col-span-3 sm:col-span-1 bg-quartz-50 dark:bg-quartz-800 rounded-lg border border-quartz-200 dark:border-quartz-700 p-4">
              <div class="h-2 w-16 bg-quartz-200 dark:bg-quartz-700 rounded mb-3"></div>
              <div class="h-8 w-24 bg-quartz-900 dark:bg-quartz-100 rounded mb-1"></div>
              <div class="h-2 w-20 bg-[#059669]/40 rounded"></div>
            </div>
            <div class="col-span-3 sm:col-span-1 bg-quartz-50 dark:bg-quartz-800 rounded-lg border border-quartz-200 dark:border-quartz-700 p-4">
              <div class="h-2 w-20 bg-quartz-200 dark:bg-quartz-700 rounded mb-3"></div>
              <div class="h-8 w-20 bg-quartz-900 dark:bg-quartz-100 rounded mb-1"></div>
              <div class="h-2 w-16 bg-[#0891B2]/40 rounded"></div>
            </div>
            <div class="col-span-3 sm:col-span-1 bg-quartz-50 dark:bg-quartz-800 rounded-lg border border-quartz-200 dark:border-quartz-700 p-4">
              <div class="h-2 w-14 bg-quartz-200 dark:bg-quartz-700 rounded mb-3"></div>
              <div class="h-8 w-28 bg-quartz-900 dark:bg-quartz-100 rounded mb-1"></div>
              <div class="h-2 w-12 bg-[#D97706]/40 rounded"></div>
            </div>
            <div class="col-span-3 bg-quartz-50 dark:bg-quartz-800 rounded-lg border border-quartz-200 dark:border-quartz-700 p-4 h-28">
              <div class="h-2 w-24 bg-quartz-200 dark:bg-quartz-700 rounded mb-4"></div>
              <div class="flex items-end gap-1 h-14">
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:40%"></div>
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:60%"></div>
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:45%"></div>
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:80%"></div>
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:55%"></div>
                <div class="flex-1 bg-[#0891B2] rounded-t" style="height:90%"></div>
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:70%"></div>
                <div class="flex-1 bg-quartz-200 dark:bg-quartz-700 rounded-t" style="height:85%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>
      </div>
    </section>

    <section id="cta">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">CTA</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Call-to-action banner with headline, supporting text, and one or two action buttons.</p>
        <a href="/aesthetics/quartz/components/cta.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="space-y-6">

    <!-- Variant 1: Full-width banner CTA -->
    <section class="relative overflow-hidden rounded-lg px-8 py-14 sm:px-16 text-center bg-[#0E7490]">
      <div class="absolute top-0 right-0 w-80 h-80 bg-white/10 rounded-full translate-x-1/3 -translate-y-1/3 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="font-['Bricolage_Grotesque'] text-3xl sm:text-4xl font-bold text-white leading-tight">
          Ready to streamline your finances?
        </h2>
        <p class="mt-4 text-base sm:text-lg text-cyan-100 max-w-xl mx-auto leading-relaxed font-['Instrument_Sans']">
          Join 1,800+ finance teams who close their books faster. Setup takes less than ten minutes.
          No credit card required.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-[#0E7490] bg-white rounded hover:bg-cyan-50 transition-all shadow-lg shadow-black/15"
          >
            Get started free
          </a>
          <a
            href="#"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white border border-white/40 rounded hover:bg-white/10 transition-colors"
          >
            Talk to sales
          </a>
        </div>
        <p class="mt-5 text-sm text-cyan-200">14-day free trial &middot; Cancel anytime &middot; SOC 2 Type II certified</p>
      </div>
    </section>

    <!-- Variant 2: Card-style centered CTA -->
    <section class="bg-white dark:bg-quartz-800 border border-quartz-200 dark:border-quartz-700 rounded-lg px-8 py-10 text-center max-w-lg mx-auto shadow-sm">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-[#ECFEFF] dark:bg-[#0891B2]/20 mb-5">
        <svg class="w-6 h-6 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <h2 class="font-['Bricolage_Grotesque'] text-xl font-bold text-quartz-900 dark:text-white">
        Start your free trial today
      </h2>
      <p class="mt-3 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
        No setup fees. No long-term contracts. Just powerful financial tools for your team, ready in minutes.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="#"
          class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-[#0891B2] rounded hover:bg-[#0E7490] transition-colors shadow-sm"
        >
          Create free account
        </a>
        <a
          href="#"
          class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-sm font-medium text-quartz-700 dark:text-quartz-300 border border-quartz-300 dark:border-quartz-600 rounded hover:bg-quartz-50 dark:hover:bg-quartz-700 transition-colors"
        >
          Learn more
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>

      </div>
    </section>

    <section id="feature-grid">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Feature Grid</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Multi-feature showcase grid with icon, title, and short description per feature.</p>
        <a href="/aesthetics/quartz/components/feature-grid.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
    <section class="bg-white dark:bg-quartz-900 rounded-lg border border-quartz-200 dark:border-quartz-800 px-8 py-14 sm:px-12 shadow-sm">

      <!-- Section header -->
      <div class="text-center mb-12">
        <h2 class="font-['Bricolage_Grotesque'] text-3xl font-bold text-quartz-900 dark:text-white">
          Everything your finance team needs
        </h2>
        <p class="mt-3 text-base text-quartz-600 dark:text-quartz-400 max-w-xl mx-auto leading-relaxed font-['Instrument_Sans']">
          Clearledger brings together the tools and workflows that modern finance teams rely on every day.
        </p>
      </div>

      <!-- 3-column feature grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Feature 1 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded bg-[#ECFEFF] dark:bg-[#0891B2]/20 shrink-0">
            <svg class="w-5 h-5 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-['Bricolage_Grotesque'] text-sm font-semibold text-quartz-900 dark:text-white">Expense tracking</h3>
            <p class="mt-1 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
              Capture receipts automatically, categorize spend in real time, and enforce policy limits before charges hit your books.
            </p>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded bg-[#ECFEFF] dark:bg-[#0891B2]/20 shrink-0">
            <svg class="w-5 h-5 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-['Bricolage_Grotesque'] text-sm font-semibold text-quartz-900 dark:text-white">Approval workflows</h3>
            <p class="mt-1 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
              Route purchase orders, invoices, and reimbursements through configurable approval chains. Set thresholds by department, vendor, or amount.
            </p>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded bg-[#ECFEFF] dark:bg-[#0891B2]/20 shrink-0">
            <svg class="w-5 h-5 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div>
            <h3 class="font-['Bricolage_Grotesque'] text-sm font-semibold text-quartz-900 dark:text-white">Cash flow forecasting</h3>
            <p class="mt-1 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
              Predict your runway with AI-powered projections. Model scenarios, stress-test assumptions, and present board-ready forecasts in minutes.
            </p>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded bg-[#ECFEFF] dark:bg-[#0891B2]/20 shrink-0">
            <svg class="w-5 h-5 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-['Bricolage_Grotesque'] text-sm font-semibold text-quartz-900 dark:text-white">Corporate cards</h3>
            <p class="mt-1 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
              Issue virtual and physical cards with built-in spend limits. Transactions sync automatically with your GL — no more manual reconciliation.
            </p>
          </div>
        </div>

        <!-- Feature 5 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded bg-[#ECFEFF] dark:bg-[#0891B2]/20 shrink-0">
            <svg class="w-5 h-5 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-['Bricolage_Grotesque'] text-sm font-semibold text-quartz-900 dark:text-white">Automated reporting</h3>
            <p class="mt-1 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
              Generate P&amp;L statements, balance sheets, and custom reports on a schedule. Share with stakeholders via PDF, CSV, or direct dashboard links.
            </p>
          </div>
        </div>

        <!-- Feature 6 -->
        <div class="flex flex-col gap-3">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded bg-[#ECFEFF] dark:bg-[#0891B2]/20 shrink-0">
            <svg class="w-5 h-5 text-[#0891B2] dark:text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
            </svg>
          </div>
          <div>
            <h3 class="font-['Bricolage_Grotesque'] text-sm font-semibold text-quartz-900 dark:text-white">ERP integration</h3>
            <p class="mt-1 text-sm text-quartz-600 dark:text-quartz-400 leading-relaxed font-['Instrument_Sans']">
              Sync bidirectionally with NetSuite, QuickBooks, Xero, and Sage. Push journal entries and pull vendor data without manual imports.
            </p>
          </div>
        </div>

      </div>
    </section>
    </section>

    <section id="testimonial">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Testimonial</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Pull quote with attribution name, title, and optional avatar.</p>
        <a href="/aesthetics/quartz/components/testimonial.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
    <section class="bg-white dark:bg-quartz-900 rounded-lg border border-quartz-200 dark:border-quartz-800 px-8 py-14 sm:px-12 shadow-sm">

      <!-- Section header -->
      <div class="text-center mb-10">
        <h2 class="font-['Bricolage_Grotesque'] text-2xl font-bold text-quartz-900 dark:text-white">Trusted by finance leaders everywhere</h2>
        <p class="mt-2 text-sm text-quartz-500 dark:text-quartz-400 font-['Instrument_Sans']">Don't take our word for it — here's what our customers say.</p>
      </div>

      <!-- Testimonial grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Testimonial 1: Featured (dark cyan bg) -->
        <figure class="flex flex-col justify-between bg-[#0E7490] rounded-lg p-6 sm:col-span-2 lg:col-span-1">
