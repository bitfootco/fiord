---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Quartz / Navigation" description="Wayfinding components in the Quartz aesthetic that help users move through an application or site. 6 components.">
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700&family=Instrument+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Page header -->
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div>
        <a href="/aesthetics/quartz/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Quartz</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Navigation</h1>
      </div>
      <a href="/aesthetics/quartz/" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5">&larr; All categories</a>
    </div>
  </header>

  <nav class="bg-white border-b border-gray-100 dark:bg-gray-900 dark:border-gray-700 px-6 py-2">
    <div class="max-w-4xl mx-auto flex gap-5 text-sm">
      <a href="#navbar" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Navbar</a>
      <a href="#sidebar" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Sidebar</a>
      <a href="#breadcrumb" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Breadcrumb</a>
      <a href="#tabs" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Tabs</a>
      <a href="#pagination" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Pagination</a>
      <a href="#footer" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Footer</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-16">

    <section id="navbar">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Navbar</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Top navigation bar with logo, link list, and action slot.</p>
        <a href="/aesthetics/quartz/components/navbar.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <nav class="rounded-lg border border-quartz-200 bg-white dark:border-quartz-700 dark:bg-quartz-800" style="box-shadow: 0 1px 2px rgba(15,30,46,0.06), 0 1px 1px rgba(15,30,46,0.04);" aria-label="Main navigation">
        <div class="mx-auto max-w-7xl px-4 sm:px-6">
          <div class="flex h-16 items-center justify-between">
            <!-- Logo -->
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded bg-quartz-900 dark:bg-quartz-100">
                <svg class="h-5 w-5 text-white dark:text-quartz-900" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                </svg>
              </div>
              <span class="text-base font-semibold text-quartz-900 dark:text-quartz-100">Clearwater</span>
            </div>
            <!-- Desktop nav links -->
            <div class="hidden items-center gap-1 md:flex">
              <a href="#" class="rounded px-3 py-2 text-sm font-medium text-quartz-500 hover:bg-quartz-100 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700 dark:hover:text-quartz-100">Markets</a>
              <a href="#" class="rounded px-3 py-2 text-sm font-medium text-quartz-500 hover:bg-quartz-100 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700 dark:hover:text-quartz-100">Solutions</a>
              <a href="#" class="rounded px-3 py-2 text-sm font-medium text-quartz-500 hover:bg-quartz-100 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700 dark:hover:text-quartz-100">Pricing</a>
              <a href="#" class="rounded px-3 py-2 text-sm font-medium text-quartz-500 hover:bg-quartz-100 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700 dark:hover:text-quartz-100">Docs</a>
              <a href="#" class="rounded px-3 py-2 text-sm font-medium text-quartz-500 hover:bg-quartz-100 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700 dark:hover:text-quartz-100">Insights</a>
            </div>
            <!-- Desktop CTA buttons -->
            <div class="hidden items-center gap-2 md:flex">
              <a href="#" class="rounded px-3 py-2 text-sm font-medium text-quartz-600 hover:bg-quartz-100 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700 dark:hover:text-quartz-100">Log in</a>
              <a href="#" class="rounded bg-[#0891B2] px-4 py-2 text-sm font-medium text-white hover:bg-[#0E7490] focus:outline-none focus:ring-2 focus:ring-[#06B6D4] focus:ring-offset-2 dark:bg-[#06B6D4] dark:hover:bg-[#0891B2] dark:focus:ring-offset-quartz-900">Sign up</a>
            </div>
            <!-- Mobile hamburger (non-functional, structural) -->
            <button
              type="button"
              class="inline-flex items-center justify-center rounded p-2 text-quartz-500 hover:bg-quartz-100 hover:text-quartz-700 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-quartz-500 md:hidden dark:text-quartz-400 dark:hover:bg-quartz-700"
              aria-expanded="false"
              aria-label="Open main menu"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
          </div>
        </div>
      </nav>
    </section>

    <section id="sidebar">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Sidebar</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Vertical navigation panel with grouped links, icons, and active state.</p>
        <a href="/aesthetics/quartz/components/sidebar.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <aside class="flex h-[600px] w-64 flex-col rounded-lg border border-quartz-200 bg-white dark:border-quartz-700 dark:bg-quartz-800" aria-label="Sidebar navigation">
        <!-- Logo -->
        <div class="flex items-center gap-2 border-b border-quartz-200 px-4 py-4 dark:border-quartz-700">
          <div class="flex h-8 w-8 items-center justify-center rounded bg-quartz-900 dark:bg-quartz-100">
            <svg class="h-5 w-5 text-white dark:text-quartz-900" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <span class="text-sm font-semibold text-quartz-900 dark:text-quartz-100">Clearwater</span>
        </div>
        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Primary">
          <ul class="space-y-0.5">
            <!-- Dashboard — active -->
            <li>
              <a href="#" class="flex items-center gap-3 rounded bg-[#ECFEFF] px-3 py-2 text-sm font-medium text-[#0891B2] dark:bg-[#0891B2]/20 dark:text-[#06B6D4]" aria-current="page">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                </svg>
                Dashboard
              </a>
            </li>
            <!-- Transactions -->
            <li>
              <a href="#" class="flex items-center gap-3 rounded px-3 py-2 text-sm font-medium text-quartz-600 hover:bg-quartz-50 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700/50 dark:hover:text-quartz-100">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
                Transactions
                <span class="ml-auto inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-quartz-200 px-1.5 text-xs font-medium text-quartz-600 dark:bg-quartz-600 dark:text-quartz-300">47</span>
              </a>
            </li>
            <!-- Reports -->
            <li>
              <a href="#" class="flex items-center gap-3 rounded px-3 py-2 text-sm font-medium text-quartz-600 hover:bg-quartz-50 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700/50 dark:hover:text-quartz-100">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
                Reports
              </a>
            </li>
            <!-- Accounts -->
            <li>
              <a href="#" class="flex items-center gap-3 rounded px-3 py-2 text-sm font-medium text-quartz-600 hover:bg-quartz-50 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700/50 dark:hover:text-quartz-100">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                </svg>
                Accounts
              </a>
            </li>
            <!-- Divider -->
            <li class="pt-3 pb-1">
              <p class="px-3 text-xs font-medium uppercase tracking-wider text-quartz-400 dark:text-quartz-500">Administration</p>
            </li>
            <!-- Compliance -->
            <li>
              <a href="#" class="flex items-center gap-3 rounded px-3 py-2 text-sm font-medium text-quartz-600 hover:bg-quartz-50 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700/50 dark:hover:text-quartz-100">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
                Compliance
              </a>
            </li>
            <!-- Settings -->
            <li>
              <a href="#" class="flex items-center gap-3 rounded px-3 py-2 text-sm font-medium text-quartz-600 hover:bg-quartz-50 hover:text-quartz-900 dark:text-quartz-400 dark:hover:bg-quartz-700/50 dark:hover:text-quartz-100">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Settings
              </a>
            </li>
          </ul>
        </nav>
        <!-- User profile -->
        <div class="border-t border-quartz-200 px-3 py-3 dark:border-quartz-700">
          <button class="flex w-full items-center gap-3 rounded px-2 py-2 text-left hover:bg-quartz-50 dark:hover:bg-quartz-700/50">
            <img
              src="https://ui-avatars.com/api/?name=Rachel+Kim&background=0891b2&color=fff&size=32"
              alt="Rachel Kim"
              class="h-8 w-8 rounded-full shrink-0"
            >
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-quartz-900 dark:text-quartz-100">Rachel Kim</p>
              <p class="truncate text-xs text-quartz-500 dark:text-quartz-400">rachel@clearwater.com</p>
            </div>
            <svg class="h-4 w-4 shrink-0 text-quartz-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
      </aside>
    </section>

    <section id="breadcrumb">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Breadcrumb</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Hierarchical path indicator with separator glyphs and truncation on long paths.</p>
        <a href="/aesthetics/quartz/components/breadcrumb.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="space-y-8">
        <!-- Simple text breadcrumb -->
        <nav aria-label="Breadcrumb">
          <ol class="flex items-center gap-1.5 text-sm">
            <li>
              <a href="#" class="text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">Home</a>
            </li>
            <li class="text-quartz-400 dark:text-quartz-600" aria-hidden="true">/</li>
            <li>
              <a href="#" class="text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">Products</a>
            </li>
            <li class="text-quartz-400 dark:text-quartz-600" aria-hidden="true">/</li>
            <li>
              <a href="#" class="text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">Software</a>
            </li>
            <li class="text-quartz-400 dark:text-quartz-600" aria-hidden="true">/</li>
            <li>
              <span class="font-medium text-quartz-900 dark:text-quartz-100" aria-current="page">Developer Tools</span>
            </li>
          </ol>
        </nav>
        <!-- Breadcrumb with chevron icons -->
        <nav aria-label="Breadcrumb">
          <ol class="flex items-center gap-1 text-sm">
            <li>
              <a href="#" class="flex items-center gap-1 text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
                Home
              </a>
            </li>
            <li aria-hidden="true">
              <svg class="h-4 w-4 text-quartz-400 dark:text-quartz-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </li>
            <li>
              <a href="#" class="text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">Products</a>
            </li>
            <li aria-hidden="true">
              <svg class="h-4 w-4 text-quartz-400 dark:text-quartz-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </li>
            <li>
              <a href="#" class="text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">Software</a>
            </li>
            <li aria-hidden="true">
              <svg class="h-4 w-4 text-quartz-400 dark:text-quartz-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </li>
            <li>
              <span class="font-medium text-quartz-900 dark:text-quartz-100" aria-current="page">Developer Tools</span>
            </li>
          </ol>
        </nav>
        <!-- Breadcrumb with truncation (collapsed middle) -->
        <nav aria-label="Breadcrumb">
          <ol class="flex items-center gap-1 text-sm">
            <li>
              <a href="#" class="text-quartz-500 hover:text-quartz-700 dark:text-quartz-400 dark:hover:text-quartz-200">Home</a>
            </li>
            <li aria-hidden="true">
              <svg class="h-4 w-4 text-quartz-400 dark:text-quartz-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
