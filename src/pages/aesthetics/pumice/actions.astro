---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Pumice / Actions" description="Action components in the Pumice aesthetic. 4 components.">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div>
        <a href="/aesthetics/pumice/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Pumice</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Actions</h1>
      </div>
      <a href="/aesthetics/pumice/" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5">&larr; All categories</a>
    </div>
  </header>

  <nav class="bg-white border-b border-gray-100 dark:bg-gray-900 dark:border-gray-700 px-6 py-2">
    <div class="max-w-4xl mx-auto flex gap-5 text-sm">
      <a href="#button" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Button</a>
      <a href="#button-group" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Button Group</a>
      <a href="#link" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Link</a>
      <a href="#dropdown" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Dropdown</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-16">

    <!-- Button -->
    <section id="button">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Button</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Primary, secondary, ghost, and destructive button variants with hover and focus states.</p>
        <a href="/aesthetics/pumice/components/button.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <!-- Variants -->
        <div class="space-y-6">
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Variants</p>
            <div class="flex flex-wrap gap-3">
              <button class="px-5 py-2.5 bg-[#D4440F] text-white text-sm font-medium font-['DM_Sans'] rounded-lg hover:bg-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150">
                Get started
              </button>
              <button class="px-5 py-2.5 bg-white text-[#1C1816] text-sm font-medium font-['DM_Sans'] rounded-lg border border-[#E5DFD6] hover:bg-[#F3F0EA] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150 dark:bg-[#1C1816] dark:text-[#F3F0EA] dark:border-[#3A3530] dark:hover:bg-[#2A2522]">
                Learn more
              </button>
              <button class="px-5 py-2.5 text-[#78716C] text-sm font-medium font-['DM_Sans'] rounded-lg hover:bg-[#F3F0EA] hover:text-[#1C1816] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150 dark:hover:bg-[#2A2522] dark:hover:text-[#F3F0EA]">
                Maybe later
              </button>
              <button class="px-5 py-2.5 bg-red-600 text-white text-sm font-medium font-['DM_Sans'] rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors duration-150">
                Delete account
              </button>
            </div>
          </div>

          <!-- Sizes -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Sizes</p>
            <div class="flex flex-wrap items-center gap-3">
              <button class="px-3.5 py-1.5 bg-[#D4440F] text-white text-xs font-medium font-['DM_Sans'] rounded-lg hover:bg-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150">
                Small
              </button>
              <button class="px-5 py-2.5 bg-[#D4440F] text-white text-sm font-medium font-['DM_Sans'] rounded-lg hover:bg-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150">
                Medium
              </button>
              <button class="px-6 py-3 bg-[#D4440F] text-white text-base font-medium font-['DM_Sans'] rounded-lg hover:bg-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150">
                Large
              </button>
            </div>
          </div>

          <!-- Disabled -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Disabled</p>
            <div class="flex flex-wrap gap-3">
              <button disabled class="px-5 py-2.5 bg-[#D4440F] text-white text-sm font-medium font-['DM_Sans'] rounded-lg opacity-40 cursor-not-allowed">
                Get started
              </button>
              <button disabled class="px-5 py-2.5 bg-white text-[#1C1816] text-sm font-medium font-['DM_Sans'] rounded-lg border border-[#E5DFD6] opacity-40 cursor-not-allowed dark:bg-[#1C1816] dark:text-[#F3F0EA]">
                Learn more
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Button Group -->
    <section id="button-group">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Button Group</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Horizontally grouped action buttons with joined borders and shared context.</p>
        <a href="/aesthetics/pumice/components/button-group.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <div class="space-y-6">
          <!-- Text formatting group -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Text formatting</p>
            <div class="inline-flex rounded-lg border border-[#E5DFD6] overflow-hidden dark:border-[#3A3530]">
              <button class="px-4 py-2 text-sm font-bold font-['DM_Sans'] text-[#1C1816] bg-white hover:bg-[#F3F0EA] border-r border-[#E5DFD6] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#D4440F] transition-colors duration-150 dark:bg-[#1C1816] dark:text-[#F3F0EA] dark:border-[#3A3530] dark:hover:bg-[#2A2522]">
                B
              </button>
              <button class="px-4 py-2 text-sm italic font-['DM_Sans'] text-[#1C1816] bg-white hover:bg-[#F3F0EA] border-r border-[#E5DFD6] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#D4440F] transition-colors duration-150 dark:bg-[#1C1816] dark:text-[#F3F0EA] dark:border-[#3A3530] dark:hover:bg-[#2A2522]">
                I
              </button>
              <button class="px-4 py-2 text-sm underline font-['DM_Sans'] text-[#1C1816] bg-white hover:bg-[#F3F0EA] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#D4440F] transition-colors duration-150 dark:bg-[#1C1816] dark:text-[#F3F0EA] dark:hover:bg-[#2A2522]">
                U
              </button>
            </div>
          </div>

          <!-- Alignment group with active state -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Alignment (center active)</p>
            <div class="inline-flex rounded-lg border border-[#E5DFD6] overflow-hidden dark:border-[#3A3530]">
              <button class="px-4 py-2 text-[#78716C] bg-white hover:bg-[#F3F0EA] border-r border-[#E5DFD6] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#D4440F] transition-colors duration-150 dark:bg-[#1C1816] dark:border-[#3A3530] dark:hover:bg-[#2A2522]" title="Align left">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h10M4 18h12"/></svg>
              </button>
              <button class="px-4 py-2 text-white bg-[#D4440F] border-r border-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#D4440F] transition-colors duration-150" title="Align center" aria-pressed="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M7 12h10M6 18h12"/></svg>
              </button>
              <button class="px-4 py-2 text-[#78716C] bg-white hover:bg-[#F3F0EA] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#D4440F] transition-colors duration-150 dark:bg-[#1C1816] dark:hover:bg-[#2A2522]" title="Align right">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M10 12h10M8 18h12"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Link -->
    <section id="link">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Link</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Styled anchor with underline, hover, and focus states for inline and standalone use.</p>
        <a href="/aesthetics/pumice/components/link.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <div class="space-y-6">
          <!-- Inline text link -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Inline</p>
            <p class="text-sm font-['DM_Sans'] text-[#1C1816] leading-relaxed dark:text-[#E8E3DC]">
              We've updated our
              <a href="#" class="text-[#D4440F] underline underline-offset-2 hover:text-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:rounded transition-colors duration-150">Terms of Service</a>
              and
              <a href="#" class="text-[#D4440F] underline underline-offset-2 hover:text-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:rounded transition-colors duration-150">Privacy Policy</a>
              effective January 1st. Please review the changes before continuing.
            </p>
          </div>

          <!-- Standalone link with arrow -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Standalone</p>
            <div class="space-y-2">
              <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium font-['DM_Sans'] text-[#D4440F] hover:text-[#B83A0C] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:rounded transition-colors duration-150 group">
                View full changelog
                <svg class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Muted link variant -->
          <div>
            <p class="text-xs font-medium font-['DM_Sans'] uppercase tracking-widest text-[#78716C] mb-3">Muted</p>
            <div class="flex flex-wrap gap-4">
              <a href="#" class="text-sm font-['DM_Sans'] text-[#78716C] hover:text-[#1C1816] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:rounded transition-colors duration-150 dark:hover:text-[#E8E3DC]">Help center</a>
              <a href="#" class="text-sm font-['DM_Sans'] text-[#78716C] hover:text-[#1C1816] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:rounded transition-colors duration-150 dark:hover:text-[#E8E3DC]">Status page</a>
              <a href="#" class="text-sm font-['DM_Sans'] text-[#78716C] hover:text-[#1C1816] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:rounded transition-colors duration-150 dark:hover:text-[#E8E3DC]">Contact us</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Dropdown -->
    <section id="dropdown">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Dropdown</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Click-triggered action menu with keyboard navigation and outside-click dismissal.</p>
        <a href="/aesthetics/pumice/components/dropdown.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone &rarr;</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden" style="min-height: 14rem;">
        <div class="relative inline-block text-left">
          <button
            type="button"
            data-fiord-dropdown-trigger="pumice-actions-menu"
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-white text-sm font-medium font-['DM_Sans'] text-[#1C1816] rounded-lg border border-[#E5DFD6] hover:bg-[#F3F0EA] focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 transition-colors duration-150 dark:bg-[#1C1816] dark:text-[#F3F0EA] dark:border-[#3A3530] dark:hover:bg-[#2A2522]"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Actions
            <svg class="w-4 h-4 text-[#78716C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <div
            id="pumice-actions-menu"
            data-fiord-dropdown-menu
            class="hidden absolute left-0 mt-2 w-52 bg-[#F3F0EA] border border-[#E5DFD6] rounded-xl z-10 overflow-hidden dark:bg-[#22201E] dark:border-[#3A3530]"
            style="box-shadow: 0 4px 16px rgba(28, 24, 20, 0.12), 0 1px 4px rgba(28, 24, 20, 0.06);"
            role="menu"
            aria-orientation="vertical"
          >
            <div class="py-1">
              <a href="#" role="menuitem" class="flex items-center gap-2.5 px-4 py-2.5 text-sm font-['DM_Sans'] text-[#1C1816] hover:bg-[#FAFAF8] transition-colors duration-100 dark:text-[#E8E3DC] dark:hover:bg-[#2A2522]">
                <svg class="w-4 h-4 text-[#78716C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Edit
              </a>
              <a href="#" role="menuitem" class="flex items-center gap-2.5 px-4 py-2.5 text-sm font-['DM_Sans'] text-[#1C1816] hover:bg-[#FAFAF8] transition-colors duration-100 dark:text-[#E8E3DC] dark:hover:bg-[#2A2522]">
                <svg class="w-4 h-4 text-[#78716C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                Duplicate
              </a>
              <a href="#" role="menuitem" class="flex items-center gap-2.5 px-4 py-2.5 text-sm font-['DM_Sans'] text-[#1C1816] hover:bg-[#FAFAF8] transition-colors duration-100 dark:text-[#E8E3DC] dark:hover:bg-[#2A2522]">
                <svg class="w-4 h-4 text-[#78716C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                Archive
              </a>
              <div class="my-1 border-t border-[#E5DFD6] dark:border-[#3A3530]"></div>
              <a href="#" role="menuitem" class="flex items-center gap-2.5 px-4 py-2.5 text-sm font-['DM_Sans'] text-red-600 hover:bg-[#FAFAF8] transition-colors duration-100 dark:hover:bg-[#2A2522]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Delete
              </a>
            </div>
          </div>
        </div>
      </div>
      <p class="mt-2 text-xs text-gray-400">Requires JS — <a href="/aesthetics/pumice/components/dropdown.html" class="underline">view standalone</a> for interactive behavior.</p>
    </section>

  </main>
</SiteLayout>
