---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Fiord — Pumice Aesthetic"
  description="Warm, human, startup-confident. Cream backgrounds and rounded forms with humanist sans-serif type and a tomato-coral accent."
>

  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

  <!-- Page header -->
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between">
        <div>
          <a href="/aesthetics/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Aesthetics</a>
          <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Pumice</h1>
        </div>
        <a href="/aesthetics/pumice/meta.json" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5 transition-colors font-mono">meta.json</a>
      </div>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 max-w-2xl">
        Warm, human, startup-confident. Cream backgrounds and rounded forms with Nunito headings and a tomato-coral accent
        that radiates energy without aggression. Built for consumer products and SaaS with a personality.
      </p>
    </div>
  </header>

  <!-- Component Catalog -->
  <main class="max-w-4xl mx-auto px-6 py-10">
    <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden divide-y divide-gray-100 dark:divide-gray-800">

      <a id="layout" href="/aesthetics/pumice/layout/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Layout</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Max-width wrappers, grids, and structural primitives for organizing page content.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="typography" href="/aesthetics/pumice/typography/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Typography</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Headings, body text, and content containers that establish textual hierarchy.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="actions" href="/aesthetics/pumice/actions/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Actions</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Interactive controls that trigger user-initiated operations.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="forms" href="/aesthetics/pumice/forms/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Forms</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">7 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Input controls and composed layouts for collecting user data.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="data" href="/aesthetics/pumice/data/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Data Display</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Components for presenting structured information, metrics, and content collections.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="navigation" href="/aesthetics/pumice/navigation/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Navigation</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Wayfinding components that help users move through an application or site.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="overlays" href="/aesthetics/pumice/overlays/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Overlays</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">5 components</span>
            <span class="text-xs bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 px-1.5 py-0.5 rounded font-mono">JS</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Floating layers that display content or interactions above the page. All include vanilla JS.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="sections" href="/aesthetics/pumice/sections/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Page Sections</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Full-page marketing and content sections ready to drop into landing pages.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

    </div>

    <p class="mt-6 text-xs text-gray-400">
      42 components across 8 categories. Copy from <a href="/aesthetics/pumice/components/" class="hover:text-gray-600 underline underline-offset-2">individual component pages</a>, not from here.
    </p>

    <!-- Design language preview -->
    <div class="mt-10">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-5">Design language</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
          <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Palette</h3>
          <div class="space-y-2">
            {[
              { name: 'Text', value: '#1C1816', hex: '#1C1816' },
              { name: 'Accent', value: '#D4440F', hex: '#D4440F' },
              { name: 'Background', value: '#FAFAF8', hex: '#FAFAF8' },
              { name: 'Surface', value: '#F3F0EA', hex: '#F3F0EA' },
              { name: 'Border', value: '#E5DFD6', hex: '#E5DFD6' },
            ].map(({ name, value, hex }) => (
              <div class="flex items-center gap-3">
                <div class="w-5 h-5 rounded border border-gray-200 flex-shrink-0" style={`background-color: ${hex}`}></div>
                <span class="text-xs text-gray-600 dark:text-gray-300 flex-1">{name}</span>
                <span class="text-xs font-mono text-gray-400 dark:text-gray-500">{value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
          <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Typography</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">Heading</p>
              <p class="font-extrabold text-gray-900 dark:text-gray-100 text-sm" style="font-family: Nunito, sans-serif;">Nunito 800</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">Body</p>
              <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed" style="font-family: 'DM Sans', sans-serif;">DM Sans 400 · 1.65 line height</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">Mono</p>
              <p class="text-gray-500 dark:text-gray-400 text-sm" style="font-family: 'Fira Code', monospace;">Fira Code 400</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>

</SiteLayout>
