---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Pumice / Demo" description="A realistic product page showcasing the Pumice aesthetic as a cohesive design system.">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative overflow-hidden bg-[#FAFAF8] dark:bg-[#1C1816]">

    <!-- Decorative blurred circles -->
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-[#D4440F]/8 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-[#E5DFD6]/40 rounded-full blur-3xl pointer-events-none dark:bg-[#3A3532]/20" aria-hidden="true"></div>

    <div class="relative px-8 pt-20 pb-12 sm:px-16 sm:pt-28 text-center">

      <!-- Eyebrow pill -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#E5DFD6] bg-white px-4 py-1.5 dark:border-[#3A3532] dark:bg-[#2C2826]">
        <span class="h-2 w-2 rounded-full bg-[#D4440F]"></span>
        <span class="font-['DM_Sans'] text-xs font-medium text-[#78716C] dark:text-[#A8A29E]">Now in open beta — join 4,000+ teams</span>
      </div>

      <!-- Headline -->
      <h1 class="mx-auto mb-6 max-w-3xl font-['Nunito'] text-4xl font-extrabold leading-tight tracking-tight text-[#1C1816] dark:text-white sm:text-5xl">
        Where teams come together to do their
        <span class="relative inline-block">
          <span class="relative z-10">best work</span>
          <span class="absolute -bottom-1 left-0 right-0 h-3 -rotate-1 rounded bg-[#FEF0EC] dark:bg-[#D4440F]/20"></span>
        </span>
      </h1>

      <!-- Subheadline -->
      <p class="mx-auto mb-10 max-w-xl font-['DM_Sans'] text-lg leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
        Rally is the team workspace that brings conversations, projects, and people into one place. Less noise, more momentum.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="#"
          class="inline-flex items-center gap-2 rounded-xl bg-[#D4440F] px-7 py-3.5 font-['DM_Sans'] text-base font-medium text-white hover:bg-[#B83A0C] transition-colors focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 dark:focus:ring-offset-[#1C1816]"
        >
          Start for free
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a
          href="#"
          class="inline-flex items-center gap-2 rounded-xl border border-[#E5DFD6] bg-white px-7 py-3.5 font-['DM_Sans'] text-base font-medium text-[#1C1816] hover:bg-[#F3F0EA] dark:border-[#3A3532] dark:bg-transparent dark:text-white dark:hover:bg-[#2C2826] transition-colors focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2 dark:focus:ring-offset-[#1C1816]"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          See how it works
        </a>
      </div>

      <!-- Social proof -->
      <p class="mt-10 font-['DM_Sans'] text-sm text-[#78716C] dark:text-[#A8A29E]">
        Trusted by teams at
        <span class="font-medium text-[#1C1816] dark:text-white">Stripe</span>,
        <span class="font-medium text-[#1C1816] dark:text-white">Notion</span>,
        <span class="font-medium text-[#1C1816] dark:text-white">Linear</span>, and 4,000+ others.
      </p>
    </div>

    <!-- Mock product screenshot -->
    <div class="relative mx-8 sm:mx-16 mb-10">
      <div class="rounded-2xl border border-[#E5DFD6] bg-white p-3 dark:border-[#3A3532] dark:bg-[#2C2826]" style="box-shadow: 0 2px 4px rgba(28,24,20,0.05), 0 6px 12px -2px rgba(28,24,20,0.08)" is:raw>
        <!-- Mock browser chrome -->
        <div class="flex items-center gap-1.5 px-4 py-3 bg-[#F3F0EA] dark:bg-[#1C1816] rounded-t-xl border-b border-[#E5DFD6] dark:border-[#3A3532]">
          <span class="w-2.5 h-2.5 rounded-full bg-[#D4440F]/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#B45309]/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#15803D]/60"></span>
          <div class="ml-2 flex-1 max-w-xs h-5 bg-white dark:bg-[#252220] rounded-md"></div>
        </div>
        <!-- Mock app layout -->
        <div class="flex min-h-[16rem] rounded-b-xl overflow-hidden bg-[#FAFAF8] dark:bg-[#1C1816]">
          <!-- Sidebar -->
          <div class="hidden sm:block w-48 border-r border-[#E5DFD6] dark:border-[#3A3532] p-4 space-y-3">
            <div class="flex items-center gap-2 mb-5">
              <div class="w-6 h-6 rounded-lg bg-[#D4440F] flex items-center justify-center">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"/></svg>
              </div>
              <span class="text-sm font-['Nunito'] font-bold text-[#1C1816] dark:text-[#F3F0EA]">Rally</span>
            </div>
            <div class="h-3 w-20 bg-[#D4440F]/10 rounded-md"></div>
            <div class="h-3 w-24 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
            <div class="h-3 w-16 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
            <div class="h-3 w-20 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
            <div class="mt-4 h-3 w-14 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
            <div class="h-3 w-24 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
            <div class="h-3 w-18 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
          </div>
          <!-- Main content area -->
          <div class="flex-1 p-5 space-y-3">
            <div class="flex items-center gap-2 mb-4">
              <div class="h-3 w-3 rounded-full bg-[#15803D]"></div>
              <div class="h-3 w-32 bg-[#E5DFD6] dark:bg-[#3A3532] rounded-md"></div>
            </div>
            <div class="rounded-xl bg-[#F3F0EA] dark:bg-[#252220] p-4 space-y-2.5">
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 rounded-full bg-[#D4440F] shrink-0 mt-0.5"></div>
                <div class="space-y-1.5 flex-1">
                  <div class="h-2.5 w-20 bg-[#1C1816]/20 dark:bg-white/20 rounded"></div>
                  <div class="h-2 w-full bg-[#E5DFD6] dark:bg-[#3A3532] rounded"></div>
                  <div class="h-2 w-3/4 bg-[#E5DFD6] dark:bg-[#3A3532] rounded"></div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 rounded-full bg-[#15803D] shrink-0 mt-0.5"></div>
                <div class="space-y-1.5 flex-1">
                  <div class="h-2.5 w-16 bg-[#1C1816]/20 dark:bg-white/20 rounded"></div>
                  <div class="h-2 w-5/6 bg-[#E5DFD6] dark:bg-[#3A3532] rounded"></div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-7 h-7 rounded-full bg-[#B45309] shrink-0 mt-0.5"></div>
                <div class="space-y-1.5 flex-1">
                  <div class="h-2.5 w-24 bg-[#1C1816]/20 dark:bg-white/20 rounded"></div>
                  <div class="h-2 w-full bg-[#E5DFD6] dark:bg-[#3A3532] rounded"></div>
                  <div class="h-2 w-2/3 bg-[#E5DFD6] dark:bg-[#3A3532] rounded"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </section>


  <!-- ═══════════════ STATS ═══════════════ -->
  <section class="bg-[#FAFAF8] dark:bg-[#1C1816] px-6 py-16 sm:py-20">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="font-['Nunito'] text-3xl font-extrabold text-[#1C1816] dark:text-white">Built for real teams, proven at scale</h2>
        <p class="mt-3 font-['DM_Sans'] text-base text-[#78716C] dark:text-[#A8A29E] max-w-xl mx-auto leading-relaxed">
          Rally powers thousands of teams, from two-person startups to hundred-person orgs.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">

        <div class="bg-[#F3F0EA] rounded-xl p-6 dark:bg-[#252220]">
          <p class="font-['DM_Sans'] text-sm text-[#78716C] mb-1 dark:text-[#A8A29E]">Active Teams</p>
          <p class="font-['Nunito'] font-extrabold text-3xl text-[#1C1816] mb-2 dark:text-[#F3F0EA]">4,200+</p>
          <div class="flex items-center gap-1.5">
            <span class="inline-flex items-center gap-0.5 rounded-full bg-[#15803D]/10 px-2 py-0.5 text-xs font-medium text-[#15803D]">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              +32%
            </span>
            <span class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">vs last quarter</span>
          </div>
        </div>

        <div class="bg-[#F3F0EA] rounded-xl p-6 dark:bg-[#252220]">
          <p class="font-['DM_Sans'] text-sm text-[#78716C] mb-1 dark:text-[#A8A29E]">Messages Sent</p>
          <p class="font-['Nunito'] font-extrabold text-3xl text-[#1C1816] mb-2 dark:text-[#F3F0EA]">2.1M</p>
          <div class="flex items-center gap-1.5">
            <span class="inline-flex items-center gap-0.5 rounded-full bg-[#15803D]/10 px-2 py-0.5 text-xs font-medium text-[#15803D]">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              +18%
            </span>
            <span class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">vs last quarter</span>
          </div>
        </div>

        <div class="bg-[#F3F0EA] rounded-xl p-6 dark:bg-[#252220]">
          <p class="font-['DM_Sans'] text-sm text-[#78716C] mb-1 dark:text-[#A8A29E]">Integrations</p>
          <p class="font-['Nunito'] font-extrabold text-3xl text-[#1C1816] mb-2 dark:text-[#F3F0EA]">140+</p>
          <div class="flex items-center gap-1.5">
            <span class="inline-flex items-center gap-0.5 rounded-full bg-[#15803D]/10 px-2 py-0.5 text-xs font-medium text-[#15803D]">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              +12 new
            </span>
            <span class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">this quarter</span>
          </div>
        </div>

        <div class="bg-[#F3F0EA] rounded-xl p-6 dark:bg-[#252220]">
          <p class="font-['DM_Sans'] text-sm text-[#78716C] mb-1 dark:text-[#A8A29E]">Uptime</p>
          <p class="font-['Nunito'] font-extrabold text-3xl text-[#1C1816] mb-2 dark:text-[#F3F0EA]">99.98%</p>
          <div class="flex items-center gap-1.5">
            <span class="inline-flex items-center gap-0.5 rounded-full bg-[#15803D]/10 px-2 py-0.5 text-xs font-medium text-[#15803D]">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              SLA met
            </span>
            <span class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">rolling 90 days</span>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════ FEATURES ═══════════════ -->
  <section class="bg-white border-y border-[#E5DFD6] dark:bg-[#1C1816] dark:border-[#3A3532] px-8 py-14 sm:px-12">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12">
        <h2 class="font-['Nunito'] text-3xl font-extrabold text-[#1C1816] dark:text-white">
          Everything your team needs in one place
        </h2>
        <p class="mt-3 font-['DM_Sans'] text-base text-[#78716C] dark:text-[#A8A29E] max-w-xl mx-auto leading-relaxed">
          Rally replaces the 6 tabs you keep open. Conversations, files, projects, and people — all in one warm, focused workspace.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Feature 1 -->
        <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3A3532] dark:bg-[#2C2826]">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
            <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
          </div>
          <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Channels</h3>
          <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Organize conversations by team, project, or topic. Public or private, with full history always searchable.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3A3532] dark:bg-[#2C2826]">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
            <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
          </div>
          <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Threaded discussions</h3>
          <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Keep side conversations out of the main flow. Threads auto-summarize so you never miss context.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3A3532] dark:bg-[#2C2826]">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
            <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          </div>
          <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">File sharing</h3>
          <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Drag and drop anything. Files live alongside conversations with previews, search, and version history built in.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3A3532] dark:bg-[#2C2826]">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
            <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Video huddles</h3>
          <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            One-click audio and video right inside any channel. No meeting links, no calendar invites, just talk.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3A3532] dark:bg-[#2C2826]">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
            <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          </div>
          <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Task boards</h3>
          <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Turn any message into a task. Lightweight boards that live alongside your conversations, not in a separate app.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3A3532] dark:bg-[#2C2826]">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
            <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </div>
          <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">140+ integrations</h3>
          <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Connect GitHub, Figma, Linear, Google Drive, and more. Notifications flow into Rally so you stay in one place.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════ TESTIMONIALS + TEAM ═══════════════ -->
  <section class="bg-[#FAFAF8] dark:bg-[#1C1816] px-6 py-16 sm:py-20">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12">
        <h2 class="font-['Nunito'] text-3xl font-extrabold text-[#1C1816] dark:text-white">Loved by teams who ship</h2>
        <p class="mt-3 font-['DM_Sans'] text-base text-[#78716C] dark:text-[#A8A29E] max-w-xl mx-auto leading-relaxed">
          Don't take our word for it. Here's what real teams say about Rally.
        </p>
      </div>

      <!-- Testimonials grid -->
      <div class="space-y-6 mb-16">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">

          <!-- Testimonial 1 -->
          <div class="rounded-2xl border border-[#E5DFD6] bg-[#F3F0EA] p-7 dark:border-[#3A3532] dark:bg-[#2C2826]" style="box-shadow: 0 2px 4px rgba(28,24,20,0.05), 0 6px 12px -2px rgba(28,24,20,0.08)">
            <div class="mb-4 font-['Nunito'] text-4xl font-extrabold leading-none text-[#D4440F]">&ldquo;</div>
            <blockquote class="mb-6 font-['DM_Sans'] text-base italic leading-relaxed text-[#1C1816] dark:text-white">
              Rally replaced Slack, Notion, and half our Jira board. Our standups went from 30 minutes to 10 because everyone already knows what's happening.
            </blockquote>
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#D4440F] font-['DM_Sans'] text-sm font-bold text-white">PM</div>
              <div>
                <p class="font-['DM_Sans'] text-sm font-medium text-[#1C1816] dark:text-white">Priya Mehta</p>
                <p class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">Head of Product, Stackwise</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="rounded-2xl border border-[#E5DFD6] bg-[#F3F0EA] p-7 dark:border-[#3A3532] dark:bg-[#2C2826]" style="box-shadow: 0 2px 4px rgba(28,24,20,0.05), 0 6px 12px -2px rgba(28,24,20,0.08)">
            <div class="mb-4 font-['Nunito'] text-4xl font-extrabold leading-none text-[#D4440F]">&ldquo;</div>
            <blockquote class="mb-6 font-['DM_Sans'] text-base italic leading-relaxed text-[#1C1816] dark:text-white">
