---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout title="Fiord — Pumice / Page Sections" description="Page section components in the Pumice aesthetic. 6 components.">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div>
        <a href="/aesthetics/pumice/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Pumice</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Page Sections</h1>
      </div>
      <a href="/aesthetics/pumice/" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5">← All categories</a>
    </div>
  </header>

  <nav class="bg-white border-b border-gray-100 dark:bg-gray-900 dark:border-gray-700 px-6 py-2">
    <div class="max-w-4xl mx-auto flex gap-5 text-sm">
      <a href="#hero" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Hero</a>
      <a href="#cta" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">CTA</a>
      <a href="#feature-grid" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Feature Grid</a>
      <a href="#testimonial" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Testimonial</a>
      <a href="#pricing-table" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">Pricing Table</a>
      <a href="#faq" class="text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 py-1">FAQ</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-16">

    <section id="hero">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Hero</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Full-width intro section with headline, subheading, and primary call-to-action.</p>
        <a href="/aesthetics/pumice/components/hero.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <section class="rounded-2xl bg-[#FAFAF8] px-8 py-20 text-center dark:bg-[#1C1816]">
          <!-- Eyebrow -->
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#E5DFD6] bg-white px-4 py-1.5 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <span class="h-2 w-2 rounded-full bg-[#D4440F]"></span>
            <span class="font-['DM_Sans'] text-xs font-medium text-[#78716C] dark:text-[#A8A29E]">Now in open beta — join 12,000+ teams</span>
          </div>

          <!-- Heading -->
          <h1 class="mx-auto mb-6 max-w-2xl font-['Nunito'] text-5xl font-extrabold leading-tight tracking-tight text-[#1C1816] dark:text-white sm:text-6xl">
            The email app for people who
            <span class="relative inline-block">
              <span class="relative z-10">hate email apps</span>
              <span class="absolute -bottom-1 left-0 right-0 h-3 -rotate-1 rounded bg-[#FEF0EC]"></span>
            </span>
          </h1>

          <!-- Subheading -->
          <p class="mx-auto mb-10 max-w-xl font-['DM_Sans'] text-lg leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Heymail is calm, focused, and built around how you actually work — not how a VC thinks you should. Your inbox is yours again.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href="#"
              class="inline-flex items-center gap-2 rounded-xl bg-[#D4440F] px-7 py-3.5 font-['DM_Sans'] text-base font-medium text-white hover:bg-[#B83A0C] transition-colors focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2"
            >
              Get started free
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="#"
              class="inline-flex items-center gap-2 rounded-xl border border-[#E5DFD6] bg-white px-7 py-3.5 font-['DM_Sans'] text-base font-medium text-[#1C1816] hover:bg-[#F3F0EA] dark:border-[#3C3430] dark:bg-transparent dark:text-white dark:hover:bg-[#2C2420] transition-colors focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2"
            >
              See how it works
            </a>
          </div>

          <!-- Social proof -->
          <p class="mt-10 font-['DM_Sans'] text-sm text-[#78716C] dark:text-[#A8A29E]">
            Loved by teams at
            <span class="font-medium text-[#1C1816] dark:text-white">Loom</span>,
            <span class="font-medium text-[#1C1816] dark:text-white">Notion</span>,
            <span class="font-medium text-[#1C1816] dark:text-white">Linear</span>, and 12,000+ others.
          </p>

          <!-- Illustration placeholder -->
          <div class="mx-auto mt-14 max-w-2xl rounded-2xl border border-[#E5DFD6] bg-white p-3 dark:border-[#3C3430] dark:bg-[#2C2420]" style="box-shadow: 0 2px 4px rgba(28,24,20,0.05), 0 6px 12px -2px rgba(28,24,20,0.08)">
            <div class="flex h-64 items-center justify-center rounded-xl bg-[#F3F0EA] dark:bg-[#1C1816]">
              <div class="space-y-3 text-center">
                <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-[#FEF0EC]">
                  <svg class="h-6 w-6 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <p class="font-['DM_Sans'] text-sm font-medium text-[#78716C] dark:text-[#A8A29E]">App preview</p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </section>

    <section id="cta">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">CTA</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Call-to-action banner with headline, supporting text, and one or two action buttons.</p>
        <a href="/aesthetics/pumice/components/cta.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <div class="space-y-6">
          <!-- Variant A: Coral background (reversed) -->
          <div class="rounded-2xl bg-[#D4440F] px-8 py-10 dark:bg-[#B83A0C]">
            <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
              <div class="max-w-md">
                <h2 class="mb-2 font-['Nunito'] text-2xl font-extrabold text-white">
                  Stop juggling five apps. Start using one.
                </h2>
                <p class="font-['DM_Sans'] text-sm leading-relaxed text-white/80">
                  Heymail brings your team's email, tasks, and docs into one calm workspace. Free for up to 5 people.
                </p>
              </div>
              <a
                href="#"
                class="inline-flex flex-shrink-0 items-center gap-2 rounded-xl bg-white px-6 py-3 font-['DM_Sans'] font-medium text-[#D4440F] hover:bg-[#FEF0EC] transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#D4440F]"
              >
                Try it free
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Variant B: Warm surface card -->
          <div class="rounded-2xl border border-[#E5DFD6] bg-[#F3F0EA] px-8 py-10 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
              <div class="max-w-md">
                <p class="mb-1 font-['DM_Sans'] text-xs font-medium uppercase tracking-wider text-[#D4440F]">Limited time</p>
                <h2 class="mb-2 font-['Nunito'] text-2xl font-extrabold text-[#1C1816] dark:text-white">
                  6 months free for early adopters
                </h2>
                <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
                  Sign up before March 31st and lock in your founding member rate — forever. No credit card required to start.
                </p>
              </div>
              <div class="flex flex-shrink-0 flex-col gap-2 sm:items-end">
                <a
                  href="#"
                  class="inline-flex items-center gap-2 rounded-xl bg-[#D4440F] px-6 py-3 font-['DM_Sans'] font-medium text-white hover:bg-[#B83A0C] transition-colors focus:outline-none focus:ring-2 focus:ring-[#D4440F] focus:ring-offset-2"
                >
                  Claim offer
                </a>
                <p class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">Offer ends March 31st</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="feature-grid">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Feature Grid</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Multi-feature showcase grid with icon, title, and short description per feature.</p>
        <a href="/aesthetics/pumice/components/feature-grid.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <div class="text-center">
          <h2 class="mb-3 font-['Nunito'] text-3xl font-extrabold text-[#1C1816] dark:text-white">
            Everything you need, nothing you don't
          </h2>
          <p class="mx-auto max-w-xl font-['DM_Sans'] text-base leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
            Heymail was built from the ground up to get out of your way and help you do real work.
          </p>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Feature 1 -->
          <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
              <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Calm inbox</h3>
            <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
              No more red badges and pinging notifications. Heymail batches your mail so you check it on your terms.
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
              <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Shared inboxes</h3>
            <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
              Support@, hello@, and billing@ all in one place. Assign threads to teammates with a click, no forwarding required.
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
              <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Built-in tasks</h3>
            <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
              Turn any email into a task without leaving the thread. Your to-do list lives right next to the email that created it.
            </p>
          </div>

          <!-- Feature 4 -->
          <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
              <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">End-to-end encryption</h3>
            <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
              Your email is private by default. We can't read it, and neither can anyone else. Zero-knowledge architecture.
            </p>
          </div>

          <!-- Feature 5 -->
          <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
              <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Instant search</h3>
            <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
              Find anything in your inbox in under 200ms. Search by sender, thread, attachment type, or date — all indexed locally.
            </p>
          </div>

          <!-- Feature 6 -->
          <div class="rounded-xl border border-[#E5DFD6] bg-[#F3F0EA] p-6 dark:border-[#3C3430] dark:bg-[#2C2420]">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#FEF0EC]">
              <svg class="h-5 w-5 text-[#D4440F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="mb-2 font-['Nunito'] text-base font-bold text-[#1C1816] dark:text-white">Smart snooze</h3>
            <p class="font-['DM_Sans'] text-sm leading-relaxed text-[#78716C] dark:text-[#A8A29E]">
              Not now, but later. Snooze any thread to resurface at the perfect moment — Monday morning, next week, after lunch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="testimonial">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Testimonial</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Pull quote with attribution name, title, and optional avatar.</p>
        <a href="/aesthetics/pumice/components/testimonial.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <div class="space-y-6">
          <!-- Testimonials grid -->
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <!-- Testimonial 1 -->
            <div class="rounded-2xl border border-[#E5DFD6] bg-[#F3F0EA] p-7 dark:border-[#3C3430] dark:bg-[#2C2420]" style="box-shadow: 0 2px 4px rgba(28,24,20,0.05), 0 6px 12px -2px rgba(28,24,20,0.08)">
              <div class="mb-4 font-['Nunito'] text-4xl font-extrabold leading-none text-[#D4440F]">"</div>
              <blockquote class="mb-6 font-['DM_Sans'] text-base italic leading-relaxed text-[#1C1816] dark:text-white">
                We switched from Gmail to Heymail six months ago and I genuinely dread going back. The shared inboxes alone saved us three hours a week.
              </blockquote>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#D4440F] font-['Nunito'] text-sm font-bold text-white">
                  SL
                </div>
                <div>
                  <p class="font-['DM_Sans'] text-sm font-medium text-[#1C1816] dark:text-white">Sophie Laurent</p>
                  <p class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">Head of Operations, Flowstate</p>
                </div>
              </div>
            </div>

            <!-- Testimonial 2 -->
            <div class="rounded-2xl border border-[#E5DFD6] bg-[#F3F0EA] p-7 dark:border-[#3C3430] dark:bg-[#2C2420]" style="box-shadow: 0 2px 4px rgba(28,24,20,0.05), 0 6px 12px -2px rgba(28,24,20,0.08)">
              <div class="mb-4 font-['Nunito'] text-4xl font-extrabold leading-none text-[#D4440F]">"</div>
              <blockquote class="mb-6 font-['DM_Sans'] text-base italic leading-relaxed text-[#1C1816] dark:text-white">
                I was skeptical — I've tried every email app. Heymail is the first one that actually changed how I work. The snooze and task features are just right.
              </blockquote>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#15803D] font-['Nunito'] text-sm font-bold text-white">
                  MK
                </div>
                <div>
                  <p class="font-['DM_Sans'] text-sm font-medium text-[#1C1816] dark:text-white">Marcus Kowalski</p>
                  <p class="font-['DM_Sans'] text-xs text-[#78716C] dark:text-[#A8A29E]">Founder, Beacon Labs</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Featured / large testimonial -->
          <div class="rounded-2xl bg-[#D4440F] px-8 py-10 dark:bg-[#B83A0C]">
            <div class="mb-4 font-['Nunito'] text-5xl font-extrabold leading-none text-white/50">"</div>
            <blockquote class="mb-6 font-['DM_Sans'] text-lg italic leading-relaxed text-white">
              Email was killing our team culture. Everyone was reactive, always catching up. Heymail gave us our mornings back. It sounds dramatic but it's the truth.
            </blockquote>
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white/20 font-['Nunito'] font-bold text-white">
                AN
              </div>
              <div>
                <p class="font-['DM_Sans'] font-medium text-white">Anya Nkemdirim</p>
                <p class="font-['DM_Sans'] text-sm text-white/70">CEO, Parallel Studio</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="pricing-table">
      <div class="mb-4">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Pricing Table</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Tier comparison layout with feature lists, price display, and highlighted recommended plan.</p>
        <a href="/aesthetics/pumice/components/pricing-table.html" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 mt-0.5 inline-block">View standalone →</a>
      </div>
      <div class="bg-[#FAFAF8] dark:bg-[#1C1816] rounded-lg border border-gray-200 dark:border-gray-700 p-6 overflow-hidden">
        <div class="text-center">
          <h2 class="mb-3 font-['Nunito'] text-3xl font-extrabold text-[#1C1816] dark:text-white">Simple, honest pricing</h2>
