---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Fiord — Chalk Aesthetic"
  description="Warm, considered, editorial. Chalk-white surface with Lora serif headings and deep forest green accents. The thinking-tool aesthetic."
>

  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500;600&family=Source+Code+Pro:wght@400;500&display=swap" rel="stylesheet">

  <!-- Page header -->
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-5">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between">
        <div>
          <a href="/aesthetics/" class="text-xs text-gray-400 hover:text-gray-600 dark:text-gray-600 dark:hover:text-gray-400 uppercase tracking-widest font-medium">Aesthetics</a>
          <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-0.5">Chalk</h1>
        </div>
        <a href="/aesthetics/chalk/meta.json" class="text-xs text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5 transition-colors font-mono">meta.json</a>
      </div>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 max-w-2xl">
        Warm, considered, editorial. A chalk-white surface with Lora serif headings and deep forest green accents.
        The thinking-tool aesthetic — note-taking apps, reading apps, writing tools, PKM. Notion, Bear, Readwise, Superhuman territory.
      </p>
    </div>
  </header>

  <!-- Component Catalog -->
  <main class="max-w-4xl mx-auto px-6 py-10">
    <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden divide-y divide-gray-100 dark:divide-gray-800">

      <a id="layout" href="/aesthetics/chalk/layout/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Layout</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Max-width wrappers, grids, and structural primitives for organizing page content.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="typography" href="/aesthetics/chalk/typography/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Typography</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Lora serif headings, DM Sans body text, and Source Code Pro for code. The aesthetic's most distinctive feature.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="actions" href="/aesthetics/chalk/actions/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Actions</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">4 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Forest green primary buttons, secondary and ghost variants, dropdowns with warm hover states.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="forms" href="/aesthetics/chalk/forms/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Forms</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">7 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Warm chalk inputs with forest-green focus rings, checkboxes, toggles, and composed form layouts.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="data" href="/aesthetics/chalk/data/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Data Display</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Cards with warm shadows, reading-list tables, serif stat numerals, badges, and avatars.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="navigation" href="/aesthetics/chalk/navigation/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Navigation</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Warm-surface navbar, sidebar, breadcrumbs, tabs with forest-green active underline, pagination.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="overlays" href="/aesthetics/chalk/overlays/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Overlays</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">5 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Modal, drawer, tooltip, popover, and toast — all with warm chalk surfaces and vanilla JS.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a id="sections" href="/aesthetics/chalk/sections/" class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 dark:text-gray-200 dark:group-hover:text-gray-100">Page Sections</span>
            <span class="text-xs text-gray-400 dark:text-gray-600">6 components</span>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-600 mt-0.5">Editorial hero with serif headline, feature grid, testimonials with Lora italic quotes, pricing, FAQ.</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

    </div>

    <!-- Design language highlight -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">Heading Font</p>
        <p class="text-lg font-semibold text-gray-900 dark:text-gray-100" style="font-family: 'Lora', Georgia, serif;">Lora Serif</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Warm, editorial, book-quality</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">Accent Color</p>
        <div class="flex items-center gap-2.5 mt-1">
          <div class="w-6 h-6 rounded" style="background: #1A5C45;"></div>
          <span class="text-sm font-mono text-gray-700 dark:text-gray-300">#1A5C45</span>
        </div>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">Deep forest green</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">Dark Mode</p>
        <div class="flex items-center gap-2.5 mt-1">
          <div class="w-6 h-6 rounded border border-gray-200" style="background: #1E1B17;"></div>
          <span class="text-sm font-mono text-gray-700 dark:text-gray-300">#1E1B17</span>
        </div>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">Warm charcoal-brown</p>
      </div>
    </div>
  </main>

</SiteLayout>
